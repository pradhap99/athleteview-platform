# AthleteView Platform — Environment Variables
# Copy to .env and fill in values

# === General ===
NODE_ENV=development
LOG_LEVEL=debug

# === Gateway (Node.js) ===
GATEWAY_PORT=3000
JWT_SECRET=your-jwt-secret-here
API_KEY_SALT=your-api-key-salt

# === AI Service ===
AI_SERVICE_PORT=8001
AI_SERVICE_HOST=0.0.0.0
MODEL_PATH=/models
TRITON_URL=localhost:8001
ONNX_PROVIDERS=CUDAExecutionProvider,CPUExecutionProvider
DEVICE=cuda  # cuda or cpu

# === Streaming ===
STREAMING_PORT=8002
SRT_LISTEN_PORT=9000
RTMP_PORT=1935
HLS_OUTPUT_DIR=/tmp/hls
FFMPEG_PATH=/usr/bin/ffmpeg

# === Biometrics ===
BIOMETRICS_PORT=8003
HR_ALERT_THRESHOLD=190
SPO2_ALERT_THRESHOLD=90
TEMP_ALERT_HIGH=39.5
TEMP_ALERT_LOW=35.0

# === Database ===
DATABASE_URL=postgresql://athleteview:password@localhost:5432/athleteview
TIMESCALE_URL=postgresql://athleteview:password@localhost:5432/athleteview_ts
REDIS_URL=redis://localhost:6379/0

# === Kafka ===
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=athleteview-platform

# === Storage ===
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_RECORDINGS=recordings
S3_BUCKET_HIGHLIGHTS=highlights

# === CDN ===
CDN_BASE_URL=https://cdn.athleteview.in
CLOUDFLARE_STREAM_TOKEN=

# === External APIs ===
HOTSTAR_API_KEY=
FANCODE_API_KEY=
JIOCINEMA_API_KEY=
